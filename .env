# Способ загрузки данных: 'kaggle' или 'local'
DATA_SOURCE_METHOD=kaggle

# ========== НАСТРОЙКА KAGGLE ==========
# Идентификатор датасета на Kaggle (формат: username/dataset-name)
KAGGLE_DATASET=ziya07/software-defect-prediction-dataset
# Имя файла внутри датасета (после распаковки)
KAGGLE_FILENAME=SoftwareDefectDataset.csv
# Путь для сохранения скачанного файла
KAGGLE_DOWNLOAD_PATH=data/raw/

# ========== ЛОКАЛЬНЫЕ ДАННЫЕ ==========
# Путь к локальному файлу (используется если DATA_SOURCE_METHOD=local)
LOCAL_DATA_PATH=data/SoftwareDefectDataset.csv

# ========== НАСТРОЙКИ ВЫВОДА ==========
# Уровень детализации логов (INFO, DEBUG)
LOG_LEVEL=INFO
# Сохранять ли промежуточные файлы
SAVE_INTERMEDIATE=true
