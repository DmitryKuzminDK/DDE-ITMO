   "source": [
    "# Простой анализ данных о дефектах ПО"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Загружаем данные\n",
    "df = pd.read_csv('../data/final/final_defect_data.csv')\n",
    "print(f\"Загружено {len(df)} строк\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Информация о данных\n",
    "df.info()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Статистика\n",
    "df.describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Проверка дефектов\n",
    "if 'defect_label' in df.columns:\n",
    "    counts = df['defect_label'].value_counts()\n",
    "    plt.figure(figsize=(8, 5))\n",
    "    counts.plot(kind='bar', color=['green', 'red'])\n",
    "    plt.title('Распределение дефектов')\n",
    "    plt.xticks([0, 1], ['Без дефектов', 'С дефектами'], rotation=0)\n",
    "    plt.ylabel('Количество')\n",
    "    \n",
    "    for i, v in enumerate(counts):\n",
    "        plt.text(i, v + 5, str(v), ha='center')\n",
    "    plt.show()\n",
    "    \n",
    "    print(f\"Дефектных модулей: {counts.get(1, 0)} ({counts.get(1, 0)/len(df)*100:.1f}%)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Смотрим на основные метрики\n",
    "metrics = ['loc', 'cyclo_complexity', 'halstead_volume']\n",
    "metrics = [m for m in metrics if m in df.columns]\n",
    "\n",
    "if metrics:\n",
    "    fig, axes = plt.subplots(1, len(metrics), figsize=(15, 4))\n",
    "    if len(metrics) == 1:\n",
    "        axes = [axes]\n",
    "    \n",
    "    for i, metric in enumerate(metrics):\n",
    "        # Логарифмическая шкала для больших значений\n",
    "        data = df[metric]\n",
    "        if data.max() > 1000:\n",
    "            data = np.log1p(data)\n",
    "            \n",
    "        axes[i].hist(data, bins=30, edgecolor='black')\n",
    "        axes[i].set_title(metric)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Корреляции\n",
    "numeric_cols = df.select_dtypes(include=['number']).columns\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.heatmap(df[numeric_cols].corr(), annot=True, fmt='.2f', cmap='coolwarm', center=0)\n",
    "plt.title('Корреляционная матрица')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Сравнение дефектных и чистых модулей\n",
    "if 'defect_label' in df.columns and len(metrics) > 0:\n",
    "    fig, axes = plt.subplots(1, len(metrics), figsize=(15, 4))\n",
    "    if len(metrics) == 1:\n",
    "        axes = [axes]\n",
    "    \n",
    "    for i, metric in enumerate(metrics):\n",
    "        data = df[[metric, 'defect_label']].copy()\n",
    "        if data[metric].max() > 1000:\n",
    "            data[metric] = np.log1p(data[metric])\n",
    "        \n",
    "        data.boxplot(column=metric, by='defect_label', ax=axes[i])\n",
    "        axes[i].set_title(f'{metric} по классам')\n",
    "        axes[i].set_xlabel('Дефект (0-нет, 1-да)')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  }
